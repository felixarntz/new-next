{
  "name": "new-next",
  "version": "0.3.1",
  "description": "CLI tool to initialize a modern, opinionated Next.js project with PNPM or Bun and Ultracite. Optionally install shadcn UI, AI SDK, and AI Elements.",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "new-next": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "doctor": "ultracite doctor"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@felixarntz/cli-utils": "^0.1.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "ultracite": "7.8.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/felixarntz/new-next.git"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
